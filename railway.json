{
  "builds": [
    {
      "src": "frontend",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    },
    {
      "src": "backend",
      "use": "@railway/php"
    }
  ],
  "routes": [
    {
      "src": "/api/*",
      "dest": "backend/api"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dist/index.html"
    }
  ]
}